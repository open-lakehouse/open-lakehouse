# ─── Credentials & secrets ──────────────────────────────────────────────
# Never commit live credentials. The `detect-secrets` pre-commit hook is a
# second line of defense; this is the first.
config/spark/spark-defaults.conf
config/unity-catalog/server.properties
.env
.env.*
!.env.example
.envrc
credentials.env
**/credentials*.env
secrets.yaml
secrets.yml
secrets.json
**/secrets/
**/.secrets/
.secrets.baseline

# Cryptographic material
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
*.truststore
*.kdbx

# Cloud provider credentials
.aws/
aws-credentials*
.gcloud/
gcloud-credentials*
.azure/

# ─── Build artifacts ────────────────────────────────────────────────────
# JARs are downloaded by scripts/tools/download-jars.sh
jars/*.jar
jars/*.jar.[0-9]*
/*.jar
node_modules/

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
.python-version
*.egg-info/
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Spark
spark-warehouse/
metastore_db/
derby.log
ivy-cache/
spark-events/
work/

# MLflow
mlruns/
mlartifacts/

# ─── Terraform ──────────────────────────────────────────────────────────
# Real tfvars contain credentials — only `.example` is tracked.
**/*.tfvars
!**/*.tfvars.example
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/*.tfstate.d/
**/.terraform.lock.hcl
**/*.tfplan

# ─── Editor / OS noise ──────────────────────────────────────────────────
.vscode/
.idea/
.history/
*.swo
*.swp
*~
*.bak
.DS_Store
Thumbs.db

# ─── Logs and tmp ───────────────────────────────────────────────────────
*.log
logs/
tmp/
.tmp/
*.tmp

# Airflow
logs/airflow/
dags/__pycache__/

# Docker
docker-compose.override.yml

# ─── Claude Code per-machine state ──────────────────────────────────────
.claude/settings.local.json
