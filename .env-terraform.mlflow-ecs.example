# Per-recipe Terraform config for terraform/mlflow-ecs.
#
# Copy to .env-terraform.mlflow-ecs and fill in. scripts/terraform/deploy-mlflow-ecs.sh
# and scripts/terraform/mlflow-ecr-push.sh source this file and map values onto
# TF_VAR_* (and the build tag), overriding the defaults in
# terraform/mlflow-ecs/variables.tf without committing a tfvars file.
#
#   .env-terraform.mlflow-ecs           -> gitignored (your real values)
#   .env-terraform.mlflow-ecs.example   -> committed (this template)

# --- Image -------------------------------------------------------------------
# Image tag to build + deploy (maps to TF_VAR_image_tag and the build/push tag).
MLFLOW_CONTAINER_RELEASE_TAG=v0.1.0

# --- AWS / ECR ---------------------------------------------------------------
# AWS region for ECR/ECS/ALB/Secrets Manager/Route 53 (maps to TF_VAR_aws_region).
AWS_REGION=us-west-2

# ECR repository name holding the MLflow image (maps to TF_VAR_ecr_repo_name).
MLFLOW_ECR_REPO=

# --- Backend store (existing PostgreSQL) -------------------------------------
# Endpoint of your existing Postgres (e.g. an RDS writer endpoint).
MLFLOW_PG_HOST=
MLFLOW_PG_PORT=5432
MLFLOW_PG_DB=mlflow
MLFLOW_PG_USER=mlflow

# Maintenance db the role connects to for CREATE DATABASE when provisioning is
# enabled (maps to TF_VAR_pg_admin_db). "postgres" for vanilla Postgres;
# "databricks_postgres" for Databricks Lakebase. Ignored when skipping provisioning.
MLFLOW_PG_ADMIN_DB=postgres

# DB password handling. Two options:
#   A) Supply MLFLOW_PG_PASSWORD_SECRET_ARN below (a secret you created) and the
#      task injects it as MLFLOW_PG_PASS.
#   B) Leave the ARN empty and set MLFLOW_PG_PASSWORD instead; deploy-mlflow-ecs.sh
#      creates/updates a Secrets Manager secret (named MLFLOW_PG_SECRET_NAME) from
#      it on deploy. The plaintext stays only in this gitignored file.
MLFLOW_PG_PASSWORD_SECRET_ARN=
# MLFLOW_PG_PASSWORD=
# MLFLOW_PG_SECRET_NAME=mlflow/mlflow-pwd

# TLS mode for the backend connection (maps to TF_VAR_pg_sslmode). Managed
# Postgres such as Databricks Lakebase requires "require". Empty disables it.
MLFLOW_PG_SSLMODE=require

# Auto-provisioning (maps to TF_VAR_skip_provision). "true" assumes the role +
# db already exist. "false" lets the entrypoint CREATE the role/db on first
# start, connecting to MLFLOW_PG_ADMIN_DB; the role must hold CREATEDB
# (and CREATEROLE if the role itself must be created).
MLFLOW_SKIP_PROVISION=true

# --- Artifact store (existing S3 bucket) -------------------------------------
# Bucket + prefix MLflow proxies artifacts to/from (maps to TF_VAR_artifact_*).
# The task IAM role is granted read/write on this prefix; no static keys.
MLFLOW_ARTIFACT_BUCKET=my-mlflow-artifacts
MLFLOW_ARTIFACT_PREFIX=mlflow-artifacts

# --- DNS / TLS (optional) ----------------------------------------------------
# Public FQDN for the tracking server over HTTPS (maps to TF_VAR_domain_name).
# Leave empty for HTTP-only on the raw ALB DNS name.
MLFLOW_DOMAIN_NAME=

# Route 53 hosted zone ID that owns the domain (maps to TF_VAR_hosted_zone_id).
MLFLOW_HOSTED_ZONE_ID=

# ACM cert domain; a wildcard can cover multiple subdomains with one cert
# (maps to TF_VAR_cert_domain_name). Empty = use MLFLOW_DOMAIN_NAME.
MLFLOW_CERT_DOMAIN_NAME=*.openlakehousedemos.dev

# --- Tracking server security (optional overrides) ---------------------------
# Comma-separated overrides for the uvicorn security middleware (MLflow 3.5+).
# When empty, the module defaults --allowed-hosts to the FQDN (or "*" on HTTP)
# and --cors-allowed-origins to the https origin.
# MLFLOW_ALLOWED_HOSTS=mlflow.openlakehousedemos.dev
# MLFLOW_CORS_ALLOWED_ORIGINS=https://app.openlakehousedemos.dev
