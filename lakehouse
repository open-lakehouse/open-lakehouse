  "airflow": {
    "webserver": $airflow_web,
    "scheduler": $airflow_sched
  },
  "all_healthy": $([ "$pg_ok" = "true" ] && [ "$s3_ok" = "true" ] && [ "$spark_master" = "true" ] && echo "true" || echo "false")
}
EOF
}

