#!/bin/bash

set -e

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

# Load environment variables from .env if it exists
if [ -f "$PROJECT_ROOT/.env" ]; then
    set -a
    source "$PROJECT_ROOT/.env"
    set +a
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check for GNU tools, when on MacOS
# See also https://github.com/cloud-helpers/k8s-job-wrappers/tree/main/setGnuTools.sh
export DF_TOOL="df"
check_gnutools_on_macos() {
	DF_TOOL="gdf"
	if [ ! $(command -v $DF_TOOL) ]
	then
        echo -e "${RED}Missing GNU tools on MacOS:${NC}"
        echo -e "  ${RED}✗${NC} $DF_TOOL"
		return 1
	fi
}

# Check if a command exists
check_cmd() {
    command -v "$1" >/dev/null 2>&1
}

# Browse Iceberg data
browse_tables() {
    local table="${1:-iceberg.bronze.orders}"
    docker exec -it spark-master-41 sh -c "/opt/spark/bin/spark-sql -e \"select * from ${table} limit 10;\""
}

# Setup PostgreSQL database (create if not exists)
setup_postgres() {
    local pg_user="${POSTGRES_USER:-postgres}"
    local pg_pass="${POSTGRES_PASSWORD:-}"
    local pg_host="${POSTGRES_HOST:-localhost}"
    pg_host="${pg_host/host.docker.internal/localhost}"
    local pg_port="${POSTGRES_PORT:-5432}"
    local db_name="iceberg_catalog"

    echo -e "${YELLOW}Checking PostgreSQL database...${NC}"

    # Check if PostgreSQL is reachable
    if ! nc -z "$pg_host" "$pg_port" 2>/dev/null; then
        echo -e "   ${RED}✗${NC} PostgreSQL not reachable on $pg_host:$pg_port"
        echo -e "   ${YELLOW}→ Ensure PostgreSQL is running${NC}"
        return 1
    fi

    # Check if psql is available
    if ! check_cmd psql; then
        echo -e "   ${YELLOW}!${NC} psql not installed - cannot auto-create database"
        echo -e "   ${YELLOW}→ Manually create database: createdb $db_name${NC}"
        return 0
    fi

    # Check if database exists
    if PGPASSWORD="$pg_pass" psql -h "$pg_host" -p "$pg_port" -U "$pg_user" -d "$db_name" -c "SELECT 1;" >/dev/null 2>&1; then
        echo -e "   ${GREEN}✓${NC} Database '$db_name' exists"
        return 0
    fi

    # Database doesn't exist - attempt to create it
    echo -e "   ${YELLOW}!${NC} Database '$db_name' not found"

    # Try to connect to postgres default database to create iceberg_catalog
    if PGPASSWORD="$pg_pass" psql -h "$pg_host" -p "$pg_port" -U "$pg_user" -d postgres -c "CREATE DATABASE $db_name;" 2>/dev/null; then
        echo -e "   ${GREEN}✓${NC} Created database '$db_name'"
        return 0
    else
        echo -e "   ${RED}✗${NC} Failed to create database '$db_name'"
        echo -e "   ${YELLOW}→ Create manually: createdb -h $pg_host -U $pg_user $db_name${NC}"
        return 1
    fi
}

# Validate credential consistency between .env and spark-defaults.conf
# UC-only mode: catalog auth lives in Unity Catalog server.properties.
# Spark-side config only needs to point at the UC REST endpoint and hold S3 creds.
check_credential_consistency() {
    local has_issues=0
    local spark_conf="$PROJECT_ROOT/config/spark/spark-defaults.conf"

    if [ ! -f "$spark_conf" ]; then
        echo -e "   ${RED}✗${NC} spark-defaults.conf not found"
        return 1
    fi

    local spark_s3_key=$(grep 'spark.hadoop.fs.s3a.access.key' "$spark_conf" 2>/dev/null | awk '{print $2}')
    local spark_uc_uri=$(grep 'spark.sql.catalog.iceberg.uri' "$spark_conf" 2>/dev/null | awk '{print $2}')

    if [ "$spark_s3_key" = "your_access_key" ]; then
        echo -e "   ${YELLOW}!${NC} spark-defaults.conf has placeholder S3 access key"
        has_issues=1
    fi
    if [ -z "$spark_uc_uri" ]; then
        echo -e "   ${YELLOW}!${NC} spark.sql.catalog.iceberg.uri not set (Unity Catalog REST endpoint missing)"
        has_issues=1
    fi

    if [ -f "$PROJECT_ROOT/.env" ]; then
        source "$PROJECT_ROOT/.env"
        if [ -n "$S3_ACCESS_KEY" ] && [ -n "$spark_s3_key" ] && [ "$S3_ACCESS_KEY" != "$spark_s3_key" ]; then
            echo -e "   ${YELLOW}!${NC} S3 access key mismatch between .env and spark-defaults.conf"
            has_issues=1
        fi
    fi

    if [ $has_issues -eq 0 ]; then
        echo -e "   ${GREEN}✓${NC} Credentials consistent"
    fi

    return $has_issues
}

# Preflight checks before starting services
preflight_checks() {
    local check_postgres=${1:-true}
    local check_seaweedfs=${2:-true}
    local check_ports=${3:-true}
    local has_errors=0

    echo -e "\n${YELLOW}Running preflight checks...${NC}"

    # Check PostgreSQL connection
    if [ "$check_postgres" = true ]; then
        local pg_user="${POSTGRES_USER:-postgres}"
        local pg_pass="${POSTGRES_PASSWORD:-}"
        local pg_host="${POSTGRES_HOST:-localhost}"
        pg_host="${pg_host/host.docker.internal/localhost}"

        if PGPASSWORD="$pg_pass" psql -h "$pg_host" -U "$pg_user" -d iceberg_catalog -c "SELECT 1;" >/dev/null 2>&1; then
            echo -e "   ${GREEN}✓${NC} PostgreSQL connection OK"
        else
            echo -e "   ${RED}✗${NC} PostgreSQL connection failed"
            echo -e "   ${YELLOW}→ Check credentials in .env and ensure PostgreSQL is running${NC}"
            has_errors=1
        fi
    fi

    # Check SeaweedFS S3 endpoint
    if [ "$check_seaweedfs" = true ]; then
        local s3_endpoint="${S3_ENDPOINT:-http://localhost:8333}"
        s3_endpoint="${s3_endpoint/host.docker.internal/localhost}"

        if curl -s --connect-timeout 5 "$s3_endpoint" > /dev/null 2>&1; then
            echo -e "   ${GREEN}✓${NC} SeaweedFS S3 endpoint OK"
        else
            echo -e "   ${RED}✗${NC} SeaweedFS S3 endpoint not responding ($s3_endpoint)"
            echo -e "   ${YELLOW}→ Ensure SeaweedFS is running${NC}"
            has_errors=1
        fi
    fi

    # Check required ports are free
    if [ "$check_ports" = true ]; then
        local spark_port=$(get_spark_port)
        local spark_ui_port=$(get_spark_ui_port)
        local ports_to_check=("$spark_port:Spark Master" "$spark_ui_port:Spark UI" "9092:Kafka" "2181:Zookeeper")

        for port_info in "${ports_to_check[@]}"; do
            local port="${port_info%%:*}"
            local name="${port_info#*:}"
            if nc -z localhost "$port" 2>/dev/null; then
                # Port in use - check if it's our expected service
                case $port in
                    $spark_port|$spark_ui_port)
                        if docker ps --format '{{.Names}}' | grep -q "spark-master"; then
                            echo -e "   ${GREEN}✓${NC} Port $port ($name) - existing Spark service"
                        else
                            echo -e "   ${YELLOW}!${NC} Port $port ($name) already in use"
                        fi
                        ;;
                    9092)
                        if docker ps --format '{{.Names}}' | grep -q "^kafka$"; then
                            echo -e "   ${GREEN}✓${NC} Port $port ($name) - existing Kafka service"
                        else
                            echo -e "   ${YELLOW}!${NC} Port $port ($name) already in use"
                        fi
                        ;;
                    *)
                        echo -e "   ${YELLOW}!${NC} Port $port ($name) already in use"
                        ;;
                esac
            else
                echo -e "   ${GREEN}✓${NC} Port $port ($name) available"
            fi
        done
    fi

    return $has_errors
}

# Check prerequisites and return missing ones
check_prerequisites() {
    local missing=()
    local warnings=()

    # Required commands
    check_cmd docker || missing+=("docker")
    check_cmd poetry || missing+=("poetry")
    check_cmd curl || missing+=("curl")

    # Check docker compose (v2 plugin)
    if check_cmd docker; then
        docker compose version >/dev/null 2>&1 || missing+=("docker-compose-plugin")
    fi

    # Optional but recommended
    check_cmd nc || warnings+=("nc (netcat) - needed for port checks")
    check_cmd psql || warnings+=("psql - needed for PostgreSQL tests")

    # Check Java version for Spark
    if check_cmd java; then
        local java_version=$(java -version 2>&1 | head -1 | cut -d'"' -f2 | cut -d'.' -f1)
        if [ "$java_version" -lt 17 ] 2>/dev/null; then
            warnings+=("Java 17+ recommended (found Java $java_version)")
        fi
    else
        warnings+=("java - needed for local spark-submit")
    fi

    # Check Python version
    if check_cmd python3; then
        local py_version=$(python3 -c 'import sys; print(sys.version_info.minor)')
        if [ "$py_version" -lt 10 ] 2>/dev/null; then
            warnings+=("Python 3.10+ recommended")
        fi
    fi

    # Report results
    if [ ${#missing[@]} -gt 0 ]; then
        echo -e "${RED}Missing required tools:${NC}"
        for tool in "${missing[@]}"; do
            echo -e "  ${RED}✗${NC} $tool"
        done
        return 1
    fi

    if [ ${#warnings[@]} -gt 0 ]; then
        echo -e "${YELLOW}Warnings:${NC}"
        for warn in "${warnings[@]}"; do
            echo -e "  ${YELLOW}!${NC} $warn"
        done
    fi

    return 0
}

# Wait for a service to be ready
# Security: Uses bash -c with hardcoded commands only (never user input)
wait_for_service() {
    local name=$1
    local check_cmd=$2
    local max_attempts=${3:-30}
    local attempt=1

    # Security: Validate check_cmd only contains safe patterns
    # Only allow: nc, curl, docker, psql commands with safe arguments
    if [[ ! "$check_cmd" =~ ^(nc\ -z|curl\ -s|docker\ exec|PGPASSWORD=) ]]; then
        echo -e "   ${RED}✗${NC} Invalid check command for $name"
        return 1
    fi

    while [ $attempt -le $max_attempts ]; do
        if bash -c "$check_cmd" >/dev/null 2>&1; then
            echo -e "   ${GREEN}✓${NC} $name ready"
            return 0
        fi
        printf "   Waiting for $name... (%d/%d)\r" $attempt $max_attempts
        sleep 1
        ((attempt++))
    done
    echo -e "   ${RED}✗${NC} $name failed to start (timeout after ${max_attempts}s)"
    return 1
}

# Wait for all services to be healthy
wait_for_services() {
    local spark_port=$(get_spark_port)
    local master_container=$(get_spark_master_container)
    echo ""

    # Kafka/Zookeeper (if started)
    if docker ps --format '{{.Names}}' | grep -q '^zookeeper$'; then
        wait_for_service "Zookeeper" "nc -z localhost 2181" 30
    fi
    if docker ps --format '{{.Names}}' | grep -q '^kafka$'; then
        wait_for_service "Kafka" "nc -z localhost 9092" 30
    fi

    # Spark (if started)
    if docker ps --format '{{.Names}}' | grep -q "^${master_container}$"; then
        wait_for_service "Spark Master" "nc -z localhost $spark_port" 30
        wait_for_service "Spark UI" "curl -s http://localhost:$(get_spark_ui_port) >/dev/null" 30
    fi
}

# Fixed Spark 4.1 constants (this repo is Spark-4.1-only)
SPARK_VERSION="4.1"
get_spark_compose()          { echo "docker-compose-spark41.yml"; }
get_spark_master_container() { echo "spark-master-41"; }
get_spark_worker_container() { echo "spark-worker-41"; }
get_spark_port()             { echo "7078"; }
get_spark_ui_port()          { echo "8082"; }

# Global flags
JSON_OUTPUT=false

parse_flags() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --json) JSON_OUTPUT=true; shift ;;
            *)      shift ;;
        esac
    done
}

# Header
header() {
    echo -e "${BLUE}================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}================================${NC}"
}

# Check service status
check_service() {
    local service=$1
    local port=$2
    local name=$3
    
    if nc -z localhost $port 2>/dev/null; then
        echo -e "${GREEN}✓${NC} $name (port $port)"
        return 0
    else
        echo -e "${RED}✗${NC} $name (port $port)"
        return 1
    fi
}

# Check container
check_container() {
    local container=$1
    if docker ps --format '{{.Names}}' | grep -q "^${container}$"; then
        echo -e "${GREEN}✓${NC} $container"
        return 0
    else
        echo -e "${RED}✗${NC} $container"
        return 1
    fi
}

# Check if service is healthy (silent, returns 0/1)
is_service_healthy() {
    local port=$1
    nc -z localhost "$port" 2>/dev/null
}

# Check Airflow health via API
is_airflow_healthy() {
    curl -s --connect-timeout 2 http://localhost:8085/health 2>/dev/null | grep -q '"healthy"'
}

# Check if container is running (silent, returns 0/1)
is_container_running() {
    local container=$1
    docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${container}$"
}

