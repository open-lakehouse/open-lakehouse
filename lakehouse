# Migrate command - run schema migrations
cmd_migrate() {
    header "SCHEMA MIGRATION"
    local dry_run=false
    local migrations_dir="$PROJECT_ROOT/schemas"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run) dry_run=true; shift ;;
            *) shift ;;
        esac
    done

    # Load credentials
    source "$PROJECT_ROOT/.env" 2>/dev/null || true
    local pg_user="${POSTGRES_USER:-postgres}"
    local pg_pass="${POSTGRES_PASSWORD:-}"
    local pg_host="${POSTGRES_HOST:-localhost}"
    pg_host="${pg_host/host.docker.internal/localhost}"
    local pg_port="${POSTGRES_PORT:-5432}"
    local db_name="iceberg_catalog"

    # Check migrations directory
    if [ ! -d "$migrations_dir" ]; then
        echo -e "${YELLOW}!${NC} No schemas/ directory found"
        echo -e "   ${YELLOW}→ Create schemas/iceberg/ with migration files${NC}"
        return 0
    fi

    # Ensure migrations tracking table exists
    PGPASSWORD="$pg_pass" psql -h "$pg_host" -p "$pg_port" -U "$pg_user" -d "$db_name" -c "
        CREATE TABLE IF NOT EXISTS _migrations (
            id SERIAL PRIMARY KEY,
            filename VARCHAR(255) UNIQUE NOT NULL,
            applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        );
    " >/dev/null 2>&1

    # Find and apply migrations
    local applied_count=0
    for migration_file in $(find "$migrations_dir" -name "*.sql" -type f | sort); do
        local filename=$(basename "$migration_file")

        # Security: Validate filename contains only safe characters (alphanumeric, underscore, hyphen, dot)
        if [[ ! "$filename" =~ ^[a-zA-Z0-9_.-]+\.sql$ ]]; then
            echo -e "   ${RED}✗${NC} Skipping unsafe filename: $filename"
            continue
        fi

        # Security: Escape single quotes in filename for SQL (double them)
        local safe_filename="${filename//\'/\'\'}"

        # Check if already applied
        local is_applied=$(PGPASSWORD="$pg_pass" psql -h "$pg_host" -p "$pg_port" -U "$pg_user" -d "$db_name" -t -c "
            SELECT COUNT(*) FROM _migrations WHERE filename = '$safe_filename';
        " 2>/dev/null | tr -d ' ')

        if [ "$is_applied" = "1" ]; then
            echo -e "   ${GREEN}✓${NC} $filename (already applied)"
            continue
        fi

        if [ "$dry_run" = true ]; then
            echo -e "   ${YELLOW}→${NC} $filename (would apply)"
        else
            echo -e "   ${BLUE}→${NC} Applying $filename..."
            if PGPASSWORD="$pg_pass" psql -h "$pg_host" -p "$pg_port" -U "$pg_user" -d "$db_name" -f "$migration_file" >/dev/null 2>&1; then
                PGPASSWORD="$pg_pass" psql -h "$pg_host" -p "$pg_port" -U "$pg_user" -d "$db_name" -c "
                    INSERT INTO _migrations (filename) VALUES ('$safe_filename');
                " >/dev/null 2>&1
                echo -e "   ${GREEN}✓${NC} $filename applied"
                ((applied_count++))
            else
                echo -e "   ${RED}✗${NC} $filename failed"
                return 1
            fi
        fi
    done

    echo -e "\n${BLUE}================================${NC}"
    if [ "$dry_run" = true ]; then
        echo -e "${YELLOW}Dry run complete - no changes made${NC}"
    else
        echo -e "${GREEN}Migration complete - $applied_count new migrations applied${NC}"
    fi
}

# Setup command - validates and configures everything
cmd_setup() {
    header "LAKEHOUSE SETUP"
    local has_errors=0

    # Step 1.1: Check for GNU tools, when on MacOS
	if [ -f /usr/bin/sw_vers ]
	then	
		echo -e "\n${YELLOW}1.1. Checking for GNU tools when on MacOS...${NC}"
		if ! check_gnutools_on_macos; then
			echo -e "\n${RED}Please install GNU tools on MacOS before continuing.${NC}"
			echo "See SETUP.md for installation instructions."
			has_errors=1
		else
			echo -e "${GREEN}✓ All required tools installed when on MacOS${NC}"
		fi
	fi

    # Step 1.2: Check prerequisites
    echo -e "\n${YELLOW}1.2. Checking prerequisites...${NC}"
    if ! check_prerequisites; then
        echo -e "\n${RED}Please install missing tools before continuing.${NC}"
        echo "See SETUP.md for installation instructions."
        has_errors=1
    else
        echo -e "${GREEN}✓ All required tools installed${NC}"
    fi

    # Step 2: Check .env file
    echo -e "\n${YELLOW}2. Checking configuration files...${NC}"
    if [ ! -f "$PROJECT_ROOT/.env" ]; then
        if [ -f "$PROJECT_ROOT/.env.example" ]; then
            cp "$PROJECT_ROOT/.env.example" "$PROJECT_ROOT/.env"
            echo -e "${YELLOW}!${NC} Created .env from .env.example"
            echo -e "  ${YELLOW}→ Please edit .env with your credentials${NC}"
            has_errors=1
        else
            echo -e "${RED}✗${NC} Missing .env and .env.example"
            has_errors=1
        fi
    else
        echo -e "${GREEN}✓${NC} .env exists"
        # Validate required variables
        source "$PROJECT_ROOT/.env"
        local env_ok=1
        [ -z "$POSTGRES_USER" ] && echo -e "  ${RED}✗${NC} POSTGRES_USER not set" && env_ok=0
        [ -z "$S3_ACCESS_KEY" ] && echo -e "  ${RED}✗${NC} S3_ACCESS_KEY not set" && env_ok=0
        [ "$POSTGRES_USER" = "your_username" ] && echo -e "  ${YELLOW}!${NC} POSTGRES_USER still has default value" && env_ok=0
        [ "$S3_ACCESS_KEY" = "your_access_key_here" ] && echo -e "  ${YELLOW}!${NC} S3_ACCESS_KEY still has default value" && env_ok=0
        [ $env_ok -eq 1 ] && echo -e "  ${GREEN}✓${NC} Required variables set"
    fi

    # Step 3: Check Spark config
    if [ ! -f "$PROJECT_ROOT/config/spark/spark-defaults.conf" ]; then
        if [ -f "$PROJECT_ROOT/config/spark/spark-defaults.conf.example" ]; then
            cp "$PROJECT_ROOT/config/spark/spark-defaults.conf.example" "$PROJECT_ROOT/config/spark/spark-defaults.conf"
            echo -e "${YELLOW}!${NC} Created spark-defaults.conf from example"
            echo -e "  ${YELLOW}→ Please edit with your S3/PostgreSQL credentials${NC}"
            has_errors=1
        else
            echo -e "${RED}✗${NC} Missing spark-defaults.conf"
            has_errors=1
        fi
    else
        echo -e "${GREEN}✓${NC} spark-defaults.conf exists"
        # Validate credential consistency
        check_credential_consistency
    fi

    # Step 4: Check JARs
    echo -e "\n${YELLOW}3. Checking JAR dependencies...${NC}"
    local jars_dir="$PROJECT_ROOT/jars"
    local required_jars=(
        "iceberg-spark-runtime-4.0_2.13-1.10.0.jar"
        "hadoop-aws-3.4.1.jar"
        "aws-java-sdk-bundle-1.12.780.jar"
        "bundle-2.24.6.jar"
        "postgresql-42.7.4.jar"
    )
    local missing_jars=0
    for jar in "${required_jars[@]}"; do
        if [ ! -f "$jars_dir/$jar" ]; then
            echo -e "  ${RED}✗${NC} Missing $jar"
            missing_jars=1
        fi
    done

    if [ $missing_jars -eq 1 ]; then
        echo -e "\n${YELLOW}Downloading missing JARs...${NC}"
        if [ -f "$PROJECT_ROOT/scripts/tools/download-jars.sh" ]; then
            bash "$PROJECT_ROOT/scripts/tools/download-jars.sh"
        else
            echo -e "${RED}✗${NC} download-jars.sh not found"
            has_errors=1
        fi
    else
        echo -e "${GREEN}✓${NC} All required JARs present"
        # Verify JAR checksums if available
        if [ -f "$PROJECT_ROOT/scripts/tools/download-jars.sh" ]; then
            bash "$PROJECT_ROOT/scripts/tools/download-jars.sh" --verify-only 2>/dev/null && \
                echo -e "  ${GREEN}✓${NC} JAR checksums verified" || \
                echo -e "  ${YELLOW}!${NC} JAR checksum verification skipped"
        fi
    fi

    # Step 5: Install Python dependencies
    echo -e "\n${YELLOW}4. Installing Python dependencies...${NC}"
    if check_cmd poetry; then
        poetry install --quiet && echo -e "${GREEN}✓${NC} Python dependencies installed" || {
            echo -e "${RED}✗${NC} Poetry install failed"
            has_errors=1
        }
    fi

    # Step 6: Setup PostgreSQL database
    echo -e "\n${YELLOW}5. Setting up PostgreSQL database...${NC}"
    if check_cmd psql && [ -n "$POSTGRES_USER" ] && [ "$POSTGRES_USER" != "your_username" ]; then
        setup_postgres || has_errors=1
    else
        echo -e "   ${YELLOW}!${NC} Skipping PostgreSQL setup (psql not available or credentials not configured)"
    fi

    # Step 7: Check disk space
    echo -e "\n${YELLOW}6. Checking disk space...${NC}"
    local free_gb=$($DF_TOOL -BG "$PROJECT_ROOT" | tail -1 | awk '{print $4}' | tr -d 'G')
    if [ "$free_gb" -lt 10 ] 2>/dev/null; then
        echo -e "${YELLOW}!${NC} Low disk space: ${free_gb}GB free (10GB+ recommended)"
    else
        echo -e "${GREEN}✓${NC} Disk space OK (${free_gb}GB free)"
    fi

    # Step 8: Check for port conflicts
    echo -e "\n${YELLOW}7. Checking for port conflicts...${NC}"
    for port in 5432 8333 9092 2181 7078 8081 8082 8085 5000 5001; do
        if nc -z localhost $port 2>/dev/null; then
            case $port in
                5432) echo -e "  ${GREEN}✓${NC} Port $port in use (PostgreSQL expected)" ;;
                8333) echo -e "  ${GREEN}✓${NC} Port $port in use (SeaweedFS expected)" ;;
                *) echo -e "  ${YELLOW}!${NC} Port $port already in use" ;;
            esac
        fi
    done

    # Summary
    echo -e "\n${BLUE}================================${NC}"
    if [ $has_errors -eq 0 ]; then
        echo -e "${GREEN}Setup complete!${NC}"
        echo -e "\nNext steps:"
        echo "  1. Start services:  ./lakehouse start all"
        echo "  2. Run tests:       ./lakehouse test"
        echo "  3. Run migrations:  ./lakehouse migrate"
    else
        echo -e "${YELLOW}Setup incomplete - please address the issues above${NC}"
        echo -e "\nSee SETUP.md for detailed instructions."
        return 1
    fi
}

