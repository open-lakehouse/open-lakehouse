# Check if port is available or used by expected container
# Returns: 0 = available or used by expected service, 1 = blocked by something else
check_port_available() {
    local port=$1
    local expected_container=$2

    if ! nc -z localhost "$port" 2>/dev/null; then
        # Port is free
        return 0
    fi

    # Port is in use - check if it's our expected container
    if [ -n "$expected_container" ]; then
        if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${expected_container}$"; then
            # Our container is using it - that's fine
            return 0
        fi
    fi

    # Port is blocked by something else
    return 1
}

# Pre-start port checks for a service
check_ports_for_service() {
    local service=$1
    local has_conflicts=0
    local spark_port=$(get_spark_port)
    local spark_ui_port=$(get_spark_ui_port)
    local master_container=$(get_spark_master_container)
    local worker_container=$(get_spark_worker_container)

    echo -e "${YELLOW}Checking port availability...${NC}"

    case $service in
        spark|all)
            if ! check_port_available "$spark_port" "$master_container"; then
                echo -e "  ${RED}✗${NC} Port $spark_port (Spark Master) blocked by another process"
                has_conflicts=1
            else
                echo -e "  ${GREEN}✓${NC} Port $spark_port (Spark Master) available"
            fi

            if ! check_port_available "$spark_ui_port" "$master_container"; then
                echo -e "  ${RED}✗${NC} Port $spark_ui_port (Spark UI) blocked by another process"
                has_conflicts=1
            else
                echo -e "  ${GREEN}✓${NC} Port $spark_ui_port (Spark UI) available"
            fi

            local worker_ui_port=$((spark_ui_port + 1))
            if ! check_port_available "$worker_ui_port" "$worker_container"; then
                echo -e "  ${YELLOW}!${NC} Port $worker_ui_port (Spark Worker UI) in use"
            fi
            ;;
    esac

    case $service in
        kafka|all)
            if ! check_port_available 9092 "kafka"; then
                echo -e "  ${RED}✗${NC} Port 9092 (Kafka) blocked by another process"
                has_conflicts=1
            else
                echo -e "  ${GREEN}✓${NC} Port 9092 (Kafka) available"
            fi

            if ! check_port_available 2181 "zookeeper"; then
                echo -e "  ${RED}✗${NC} Port 2181 (Zookeeper) blocked by another process"
                has_conflicts=1
            else
                echo -e "  ${GREEN}✓${NC} Port 2181 (Zookeeper) available"
            fi
            ;;
    esac

    case $service in
        unity-catalog|uc)
            if ! check_port_available 8081 "unity-catalog"; then
                echo -e "  ${RED}✗${NC} Port 8081 (Unity Catalog) blocked by another process"
                has_conflicts=1
            else
                echo -e "  ${GREEN}✓${NC} Port 8081 (Unity Catalog) available"
            fi
            ;;
    esac

    if [ $has_conflicts -eq 1 ]; then
        echo -e "\n${RED}Port conflicts detected.${NC}"
        echo -e "${YELLOW}→ Stop conflicting services or use different ports${NC}"
        echo -e "${YELLOW}→ Run './lakehouse status' to see what's running${NC}"
        return 1
    fi

    return 0
}

# Start command
cmd_start() {
    header "STARTING SERVICES"

    local service=$1
    local compose_file=$(get_spark_compose)
    local spark_port=$(get_spark_port)

    # Check port availability before starting
    if ! check_ports_for_service "$service"; then
        echo -e "\n${RED}Aborting start due to port conflicts.${NC}"
        return 1
    fi
    echo ""

    case $service in
        spark|all)
            echo -e "${YELLOW}Starting Spark 4.1 (port $spark_port)...${NC}"
            docker compose -f "$compose_file" up -d
            ;;
    esac

    case $service in
        kafka|all)
            echo -e "${YELLOW}Starting Kafka...${NC}"
            docker compose -f docker-compose-kafka.yml up -d
            ;;
    esac

    case $service in
        unity-catalog|uc)
            echo -e "${YELLOW}Starting Unity Catalog...${NC}"
            if [ ! -f "config/unity-catalog/server.properties" ]; then
                echo -e "${YELLOW}Creating server.properties from example...${NC}"
                cp config/unity-catalog/server.properties.example config/unity-catalog/server.properties
                echo -e "${YELLOW}!${NC} Edit config/unity-catalog/server.properties with your S3 credentials"
            fi
            docker compose -f docker-compose-unity-catalog.yml up -d
            wait_for_service "Unity Catalog" "curl -s http://localhost:8081/api/2.1/unity-catalog/catalogs" 60
            ;;
    esac

    case $service in
        airflow)
            echo -e "${YELLOW}Starting Airflow...${NC}"
            mkdir -p logs/airflow
            docker compose -f docker-compose-airflow.yml up -d --build
            wait_for_service "Airflow" "curl -s http://localhost:8085/health" 120
            echo -e "${GREEN}Airflow UI available at: http://localhost:8085${NC}"
            echo -e "${YELLOW}Default credentials: admin/admin (change in .env)${NC}"
            ;;
    esac

    case $service in
        mlflow)
            echo -e "${YELLOW}Starting MLflow...${NC}"
            docker compose -f docker-compose-mlflow.yml up -d
            wait_for_service "MLflow" "curl -s http://localhost:5000/health" 60
            echo -e "${GREEN}MLflow tracking UI at: http://localhost:5000${NC}"
            ;;
    esac

    case $service in
        spark|kafka|all|unity-catalog|uc|airflow|mlflow)
            ;;
        *)
            echo "Usage: lakehouse start [spark|kafka|airflow|unity-catalog|mlflow|all]"
            exit 1
            ;;
    esac

    if [ "$service" = "all" ] || [ "$service" = "spark" ] || [ "$service" = "kafka" ]; then
        echo -e "\n${YELLOW}Waiting for services to be ready...${NC}"
        wait_for_services
        echo ""
    fi
}

# Stop command
cmd_stop() {
    header "STOPPING SERVICES"

    local service=$1
    local compose_file=$(get_spark_compose)

    case $service in
        spark|all)
            echo -e "${YELLOW}Stopping Spark 4.1...${NC}"
            docker compose -f "$compose_file" down
            ;;
    esac

    case $service in
        kafka|all)
            echo -e "${YELLOW}Stopping Kafka...${NC}"
            docker compose -f docker-compose-kafka.yml down
            ;;
    esac

    case $service in
        unity-catalog|uc)
            echo -e "${YELLOW}Stopping Unity Catalog...${NC}"
            docker compose -f docker-compose-unity-catalog.yml down
            ;;
    esac

    case $service in
        airflow)
            echo -e "${YELLOW}Stopping Airflow...${NC}"
            docker compose -f docker-compose-airflow.yml down
            ;;
    esac

    case $service in
        mlflow)
            echo -e "${YELLOW}Stopping MLflow...${NC}"
            docker compose -f docker-compose-mlflow.yml down
            ;;
    esac

    case $service in
        spark|kafka|all|unity-catalog|uc|airflow|mlflow)
            ;;
        *)
            echo "Usage: lakehouse stop [spark|kafka|airflow|unity-catalog|mlflow|all]"
            exit 1
            ;;
    esac
}

# Logs command
cmd_logs() {
    local service=$1
    local master_container=$(get_spark_master_container)
    local worker_container=$(get_spark_worker_container)

    case $service in
        spark-master)
            echo -e "${YELLOW}Logs for $master_container (Spark 4.1):${NC}"
            docker logs -f "$master_container"
            ;;
        spark-worker)
            echo -e "${YELLOW}Logs for $worker_container (Spark 4.1):${NC}"
            docker logs -f "$worker_container"
            ;;
        kafka)            docker logs -f kafka ;;
        zookeeper)        docker logs -f zookeeper ;;
        unity-catalog|uc) docker logs -f unity-catalog ;;
