# Unity Catalog OSS Server Configuration
# Copy this file to server.properties and update values for your environment
#
# Documentation: https://docs.unitycatalog.io/

# Server settings
server.env=dev
server.port=8080

# ============================================================================
# S3-Compatible Storage Configuration (SeaweedFS)
# ============================================================================
# Unity Catalog uses credential vending to provide just-in-time access
# to storage. Configure your SeaweedFS S3 credentials here.
#
# Multiple buckets can be configured using index suffixes (0, 1, 2, ...)

# Bucket 0: Main lakehouse bucket.
#
# IMPORTANT — two non-obvious requirements:
#  1. bucketPath must be the bucket ROOT (s3://lakehouse), not a sub-prefix.
#     UC matches a table's storage base against this exact value.
#  2. ALL of region/accessKey/secretKey/sessionToken must be non-null, or UC's
#     config loader (ServerProperties.getS3Configurations) silently breaks its
#     loop and skips the bucket — credential vending then fails with
#     "S3 bucket configuration not found." For static-cred (SeaweedFS) mode,
#     set sessionToken to any non-empty placeholder.
s3.bucketPath.0=s3://lakehouse
s3.region.0=us-east-1
s3.accessKey.0=your_seaweedfs_access_key
s3.secretKey.0=your_seaweedfs_secret_key
s3.sessionToken.0=not_used
# Custom endpoint for SeaweedFS (comment out for real AWS S3)
s3.endpoint.0=http://localhost:8333

# ============================================================================
# Database Configuration
# ============================================================================
# By default, Unity Catalog uses an embedded H2 database for development.
# For production, configure PostgreSQL or another supported database.
#
# Uncomment below to use PostgreSQL:
# hibernate.connection.driver_class=org.postgresql.Driver
# hibernate.connection.url=jdbc:postgresql://localhost:5432/unity_catalog
# hibernate.connection.username=postgres
# hibernate.connection.password=your_password
# hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# ============================================================================
# Authorization (Disabled by default for demos)
# ============================================================================
# UC OSS supports OAuth/OIDC for authentication. For demo purposes this is
# disabled so clients (Spark Connect, DuckDB, curl) can hit the REST API
# without a token.
#
# To enable: set server.authorization=enable and configure the rest of the
# OAuth block — see the upstream lakehouse-stack repo's server.properties
# for a Keycloak example.
server.authorization=disable
