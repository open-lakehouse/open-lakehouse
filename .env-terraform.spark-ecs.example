# Per-recipe Terraform config for terraform/spark-ecs.
#
# Copy to .env-terraform.spark-ecs and fill in. scripts/terraform/deploy-spark-ecs.sh
# and scripts/terraform/spark-ecr-push.sh source this file and map values onto TF_VAR_*
# (and the build tag), overriding the defaults in terraform/spark-ecs/variables.tf
# without committing a tfvars file.
#
#   .env-terraform.spark-ecs           -> gitignored (your real values)
#   .env-terraform.spark-ecs.example   -> committed (this template)

# --- Image -------------------------------------------------------------------
# Image tag to build + deploy (maps to TF_VAR_image_tag and the build/push tag).
SPARK_CONTAINER_RELEASE_TAG=v0.1.0

# Maven mirror used when downloading the baked JARs during the image build.
# Leave as Maven Central unless you are behind a corporate proxy/mirror.
MAVEN_PROXY_URL=https://repo1.maven.org/maven2

# --- DNS / TLS ----------------------------------------------------------------
# Public FQDN for the master UI over HTTPS (maps to TF_VAR_domain_name).
# Leave empty for HTTP-only on the raw ALB DNS name.
SPARK_CLUSTER_DOMAIN_NAME=spark.openlakehousedemos.dev

# Public FQDN for the Spark Connect gRPC endpoint (maps to TF_VAR_connect_domain_name).
SPARK_CLUSTER_CONNECT_DOMAIN_NAME=connect.openlakehousedemos.dev

# Route 53 hosted zone ID that owns the domains (maps to TF_VAR_hosted_zone_id).
SPARK_CLUSTER_HOSTED_ZONE_ID=

# ACM cert domain; a wildcard covers both subdomains with one cert
# (maps to TF_VAR_cert_domain_name).
SPARK_CLUSTER_CERT_DOMAIN_NAME=*.openlakehousedemos.dev

# --- AWS / ECR (optional; fall back to ./.env or the AWS CLI defaults) --------
# AWS region for ECR/ECS/ALB/NLB/Route 53 (maps to TF_VAR_aws_region).
AWS_REGION=us-west-2

# ECR repository name holding the Spark image (maps to TF_VAR_ecr_repo_name).
SPARK_ECR_REPO=open-lakehouse-spark
